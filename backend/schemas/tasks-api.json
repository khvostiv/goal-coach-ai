{
  "openapi": "3.0.0",
  "info": {
    "title": "Goal Coach API",
    "version": "1.0.0",
    "description": "API for creating and retrieving AI-generated goal plans stored in DynamoDB."
  },
  "paths": {
    "/goals": {
      "post": {
        "description": "Create and save a new AI-generated goal plan.",
        "operationId": "createGoalPlan",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "goal": {
                    "type": "string",
                    "description": "The user's long-term goal."
                  },
                  "deadline": {
                    "type": "string",
                    "description": "The user's deadline, such as 2026-09-15, 30 days, 6 weeks, or 2 months."
                  },
                  "dailyMinutes": {
                    "type": "integer",
                    "description": "Available time per day in minutes."
                  }
                },
                "required": [
                  "goal",
                  "deadline",
                  "dailyMinutes"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Goal plan created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "get": {
        "description": "Retrieve all saved goal plans.",
        "operationId": "listGoalPlans",
        "responses": {
          "200": {
            "description": "Goal plans retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}